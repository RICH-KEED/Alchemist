# .secrets-allowlist — suppress known-safe matches from the secrets scanner.
# One regex pattern per line.  Blank lines and #-comments are ignored.
# Patterns are tested against the *matched text* of each scanner finding.

# Demo / documentation keys used in README examples
AIzaSyDemoKey1234567890abcdefghijklm
demo_key_[a-z0-9_]+

# Known-safe base64 blobs (e.g., embedded test PNG in unit tests)
iVBORw0KGgo[A-Za-z0-9+/=]{20,}

# OAuth client secrets for local development (non-production)
not-a-real-secret-[a-z0-9]{10}

# Keystore files used only for automated testing
test/data/.*\.jks
test/data/.*\.keystore

# Whitelist a specific google-services.json used in CI/fixtures
test/fixtures/google-services\.json
