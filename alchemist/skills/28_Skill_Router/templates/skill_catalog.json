{
  "_meta": {
    "purpose": "Machine catalog used by scripts/route.py to pick the smallest set of skills for an ad-hoc request and expand its dependency closure. Each entry maps a skill id to trigger keywords and dependsOn[] (skills whose contracts/scaffolds it consumes).",
    "house_style": "../../references/CONVENTIONS.md",
    "schema": {
      "phase": "pipeline phase A-E, or X for non-pipeline / cross-cutting (token-economy, autonomy, advanced) skills",
      "triggers": "lowercase keyword/phrase fragments matched against the lowercased request (substring match)",
      "dependsOn": "skill ids this one needs in place first (contracts, scaffolds, tokens). The closure is what route.py expands.",
      "fullPipeline": "true ONLY for 01 — signals route.py to defer to the orchestrator instead of returning an ad-hoc plan"
    },
    "maintenance": "Keep dependsOn in sync with each skill's own 'For X use skill NN' cross-references. Skill Telemetry (#35) writes hit/miss data the router learns from over time; see SKILL.md."
  },

